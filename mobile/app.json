{
  "expo": {
    "name": "telifier-app",
    "slug": "telifier-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/telefya.png",
    "scheme": "telifierapp",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "translucent": true,
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#00000000",
      "barStyle": "light-content"
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Telifier needs camera access for video meetings.",
        "NSMicrophoneUsageDescription": "Telifier needs microphone access for audio meetings."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/telefya-logo.png",
        "backgroundImage": "./assets/images/telefya-logo.png",
        "monochromeImage": "./assets/images/telefya-logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-audio",
      "expo-navigation-bar",
      "expo-secure-store",
      "expo-asset",
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}